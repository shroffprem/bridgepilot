{
  "name": "Loan",
  "type": "object",
  "properties": {
    "loan_number": {
      "type": "string",
      "description": "Unique loan reference number"
    },
    "borrower_id": {
      "type": "string",
      "description": "Reference to Borrower entity"
    },
    "borrower_name": {
      "type": "string",
      "description": "Customer name"
    },
    "customer_mobile": {
      "type": "string",
      "description": "Customer mobile number"
    },
    "amount": {
      "type": "number",
      "description": "Amount to be transferred (\u20b9)"
    },
    "interest_rate": {
      "type": "number",
      "description": "Annual interest rate in %"
    },
    "tenure_days": {
      "type": "number",
      "description": "Loan duration in days"
    },
    "disbursement_date": {
      "type": "string",
      "format": "date"
    },
    "maturity_date": {
      "type": "string",
      "format": "date",
      "description": "Due date for bullet repayment"
    },
    "total_repayable": {
      "type": "number",
      "description": "Principal + interest at maturity"
    },
    "purpose": {
      "type": "string"
    },
    "branch": {
      "type": "string",
      "description": "Branch name"
    },
    "cluster": {
      "type": "string"
    },
    "zone": {
      "type": "string"
    },
    "so_name": {
      "type": "string",
      "description": "Sales Officer name"
    },
    "value_pledged": {
      "type": "number",
      "description": "Value pledged by customer"
    },
    "approx_value_offered": {
      "type": "string",
      "description": "Approx value offered by us with charges (e.g. Normal BT)"
    },
    "net_weight": {
      "type": "number",
      "description": "Net weight in grams"
    },
    "bank_name": {
      "type": "string",
      "description": "Customer bank name"
    },
    "account_number": {
      "type": "string",
      "description": "Customer bank account number"
    },
    "ifsc_code": {
      "type": "string",
      "description": "IFSC code"
    },
    "aadhar_number": {
      "type": "string",
      "description": "Aadhar card number"
    },
    "pan_number": {
      "type": "string",
      "description": "PAN card number"
    },
    "pledge_card_number": {
      "type": "string",
      "description": "Pledge card number"
    },
    "security_cheque": {
      "type": "string",
      "description": "Security cheque details"
    },
    "security_details": {
      "type": "string",
      "description": "Collateral / security offered"
    },
    "processing_fee": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "pending_cluster_approval",
        "pending_zonal_approval",
        "approved",
        "disbursed",
        "repaid",
        "overdue",
        "rejected"
      ],
      "default": "draft"
    },
    "approval_stage": {
      "type": "string",
      "enum": [
        "branch",
        "cluster",
        "zonal",
        "complete"
      ],
      "default": "branch"
    },
    "branch_manager": {
      "type": "string"
    },
    "cluster_manager_notes": {
      "type": "string"
    },
    "zonal_manager_notes": {
      "type": "string"
    },
    "rejection_reason": {
      "type": "string"
    },
    "submitted_by": {
      "type": "string"
    },
    "approved_by_cluster": {
      "type": "string"
    },
    "approved_by_zonal": {
      "type": "string"
    }
  },
  "required": [
    "borrower_name",
    "amount",
    "interest_rate",
    "tenure_days"
  ]
}